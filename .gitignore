# macOS
.DS_Store

# Xcode build artifacts
build/
DerivedData/
*.swiftpm/
.swiftpm/
.build/

# Xcode user-specific IDE state (causes merge conflicts, not portable)
xcuserdata/
*.xcuserstate
*.xcuserdatad/
*.xcworkspace/xcuserdata/
*.xcscmblueprint
*.xccheckout

# Per-user simulator/playground state
*.playground/.../timeline.xctimeline
*.swiftpm/xcode/

# Generated by XcodeGen — keep VBTrainer.xcodeproj checked in for clone-and-go,
# but ignore the user-state subfolders inside it.
VBTrainer.xcodeproj/xcuserdata/
VBTrainer.xcodeproj/project.xcworkspace/xcuserdata/
VBTrainer.xcodeproj/project.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist

# CocoaPods (not used in V1, just in case)
Pods/

# Swift Package Manager
.swiftpm/
.build/
Packages/

# Test bundle output
*.xcresult/

# OpenSpec runtime — proposals are source-of-truth (kept), but archive should
# probably be tracked too. Local OpenSpec settings:
.openspec/cache/

# IDE / Editor
*.swp
*.swo
*~
.vscode/
.idea/

# OS junk
Thumbs.db
ehthumbs.db
.Spotlight-V100
.Trashes

# Personal credentials / API keys (none in V1, but precaution for V2)
.env
.env.local
secrets.json
GoogleService-Info.plist

# Claude Code session state (kept private, not project state)
.claude/settings.local.json
